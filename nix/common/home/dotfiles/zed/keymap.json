[
  {
    "context": "Workspace",
    "bindings": { "shift shift": "file_finder::Toggle" }
  },
  {
    "context": "Editor && edit_prediction",
    "bindings": { "alt-tab": "editor::AcceptEditPrediction" }
  },
  {
    "context": "Editor",
    "bindings": { "tab": "editor::Tab" }
  },
  {
    "context": "Editor && showing_completions",
    "bindings": { "tab": "editor::ComposeCompletion" }
  },
  {
    "context": "(VimControl && !menu) || vim_mode == replace || vim_mode == waiting",
    "bindings": { "tab": "vim::Tab" }
  },
  {
    "context": "vim_mode == literal",
    "bindings": { "tab": ["vim::Literal", ["tab", "\u0009"]] }
  },
  { "bindings": { "shift-escape": "workspace::ToggleZoom" } },
  { "context": "Workspace", "bindings": { "cmd-k": null } },
  { "context": "(Workspace || Editor)", "bindings": { "cmd-shift-k": null } },
  { "context": "GitPanel", "bindings": { "ctrl-g up": null } },
  { "context": "GitPanel", "bindings": { "ctrl-g down": null } },
  {
    "context": "Workspace",
    "bindings": { "cmd-shift-j": "project_symbols::Toggle" }
  },
  { "context": "Workspace", "bindings": { "cmd-shift-n": null } }
]
