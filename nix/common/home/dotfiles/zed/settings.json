{
  "context_servers": {
//    "mcp-server-github": {
//      "enabled": true,
//      "remote": false,
//      "settings": {
//        "github_personal_access_token": "ghp_...",
//      },
//    },
  },
  "terminal": { "copy_on_select": true },
  "agent_buffer_font_size": 13.0,
  "buffer_font_size": 15.0,
  "title_bar": {
    "show_menus": false,
    "show_user_picture": true,
    "show_onboarding_banner": true,
    "show_branch_name": true,
  },
  "colorize_brackets": true,
  "collaboration_panel": { "dock": "right", "button": false },
  "helix_mode": false,
  "notification_panel": { "button": false },
  "agent_ui_font_size": 13.0,
  "theme": { "mode": "system", "light": "One Light", "dark": "One Dark" },
  "base_keymap": "JetBrains",
  "edit_predictions": { "provider": "zed", "mode": "subtle" },
  "outline_panel": { "dock": "right" },
  "languages": {
    "Proto": {
      "formatter": {
        "external": {
          "command": "clang-format",
          "arguments": ["--style=file", "--assume-filename={buffer_path}"],
        },
      },
    },
    "Nix": {
      "formatter": {
        "external": {
          "command": "nixfmt",
          "arguments": ["--strict", "--quiet", "--verify"],
        },
      },
    },
  },
  "lsp": {
    "buf": {
      "binary": { "path": "buf", "arguments": ["beta", "lsp"] },
    },
  },
  "agent": {
    "dock": "left",
    "show_turn_stats": true,
    "play_sound_when_agent_done": "always",
    "enable_feedback": false,
    "favorite_models": [
      {
        "provider": "anthropic",
        "model": "claude-opus-4-6-1m-context-thinking-latest",
        "enable_thinking": false,
      },
      {
        "provider": "zed.dev",
        "model": "claude-opus-4-6-thinking",
        "enable_thinking": false,
      },
      {
        "provider": "anthropic",
        "model": "claude-opus-4-6-thinking-latest",
        "enable_thinking": false,
      },
    ],
    "tool_permissions": { "default": "allow" },
    "use_modifier_to_send": true,
    "profiles": {
      "ask-+-terminal": {
        "name": "Ask + Terminal",
        "tools": {
          "search_web": true,
          "terminal": true,
          "contents": true,
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "thinking": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {},
      },
    },
    "default_profile": "write",
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-opus-4-6-thinking",
    },
    "default_model": {
      "effort": "max",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "claude-opus-4-7",
    },
  },
  "project_panel": {
    "dock": "right",
    "git_status": true,
    "hide_hidden": false,
    "entry_spacing": "standard",
  },
  "auto_signature_help": true,
  "double_click_in_multibuffer": "open",
  "indent_guides": {
    "background_coloring": "indent_aware",
    "coloring": "indent_aware",
  },
  "inlay_hints": {
    "show_other_hints": false,
    "enabled": false,
    "show_parameter_hints": false,
    "show_type_hints": false,
  },
  "preferred_line_length": 80,
  "format_on_save": "on",
  "show_whitespaces": "all",
  "wrap_guides": [80, 100, 120],
  "git_panel": { "dock": "right", "button": false },
  "tabs": { "file_icons": true, "git_status": true },
  "telemetry": { "diagnostics": false, "metrics": false },
  "unnecessary_code_fade": 0.5,
  "when_closing_with_no_tabs": "keep_window_open",
  "always_treat_brackets_as_autoclosed": true,
  "vim": {
    "use_system_clipboard": "on_yank",
    "toggle_relative_line_numbers": true,
  },
  "vim_mode": true,
  "ui_font_size": 13.0,
  "buffer_line_height": { "custom": 1.3 },
  "git": {
    "gutter_debounce": 5,
    "hunk_style": "staged_hollow",
    "inline_blame": {
      "enabled": true,
      "show_commit_summary": true,
      "min_column": 60,
    },
  },
  "auto_install_extensions": {
    "ast-grep": true,
    "colorizer": true,
    "csv": true,
    "dockerfile": true,
    "git-firefly": true,
    "grit": true,
    "helm": true,
    "html": true,
    "ical": true,
    "ini": true,
    "jj-lsp": true,
    "jsonl": true,
    "log": true,
    "make": true,
    "mcp-server-github": true,
    "mcp-server-linear": true,
    "mcp-server-puppeteer": true,
    "nix": true,
    "nu": true,
    "postgres-context-server": true,
    "powershell": true,
    "proto": true,
    "pylsp": true,
    "python-requirements": true,
    "rainbow-csv": true,
    "sql": true,
    "tailwind-theme": true,
    "terraform": true,
    "toml": true,
    "typescript-snippets": true,
    "xml": true,
  },
}

