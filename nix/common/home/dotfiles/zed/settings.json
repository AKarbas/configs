{
  "context_servers": {
    // "mcp-server-github": {
    //   "enabled": true,
    //   "remote": false,
    //   "settings": {
    //     "github_personal_access_token": "ghp_...",
    //   },
    // },
    // "linear": {
    //   "command": "npx",
    //   "args": ["-y", "mcp-remote", "https://mcp.linear.app/mcp"],
    //   "env": {},
    //   "settings": {},
    // },
  },
  "terminal": { "copy_on_select": true },
  "agent_buffer_font_size": 13,
  "buffer_font_size": 13,
  "agent_ui_font_size": 13,
  "ui_font_size": 13,
  "title_bar": { "show_branch_name": false },
  "colorize_brackets": true,
  "collaboration_panel": { "button": false },
  "base_keymap": "JetBrains",
  "edit_predictions": { "mode": "subtle" },
  "languages": {
    "Proto": {
      "formatter": {
        "external": {
          "command": "clang-format",
          "arguments": ["--style=file", "--assume-filename={buffer_path}"],
        },
      },
    },
    "Nix": {
      "formatter": {
        "external": {
          "command": "nixfmt",
          "arguments": ["--strict", "--quiet", "--verify"],
        },
      },
    },
  },
  "lsp": {
    "buf": {
      "binary": { "path": "buf", "arguments": ["beta", "lsp"] },
    },
  },
  "agent": {
    "message_editor_min_lines": 5,
    "single_file_review": true,
    "show_turn_stats": true,
    "play_sound_when_agent_done": "always",
    "enable_feedback": false,
    "favorite_models": [
      {
        "provider": "anthropic",
        "model": "claude-opus-4-6-1m-context-thinking-latest",
        "enable_thinking": false,
      },
      {
        "provider": "zed.dev",
        "model": "claude-opus-4-6-thinking",
        "enable_thinking": false,
      },
      {
        "provider": "anthropic",
        "model": "claude-opus-4-6-thinking-latest",
        "enable_thinking": false,
      },
    ],
    "tool_permissions": { "default": "allow" },
    "profiles": {
      "ask-+-terminal": {
        "name": "Ask + Terminal",
        "tools": {
          "search_web": true,
          "terminal": true,
          "contents": true,
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "thinking": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {},
      },
    },
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-opus-4-6-thinking",
    },
    "default_model": {
      "effort": "max",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "claude-opus-4-7",
    },
  },
  "project_panel": {
    "hide_root": true,
    "drag_and_drop": false,
    "scrollbar": { "show": "auto" },
  },
  "auto_signature_help": true,
  "double_click_in_multibuffer": "open",
  "indent_guides": {
    "background_coloring": "indent_aware",
    "coloring": "indent_aware",
  },
  "inlay_hints": {
    "show_other_hints": false,
    "show_parameter_hints": false,
    "show_type_hints": false,
  },
  "show_whitespaces": "all",
  "wrap_guides": [80, 100, 120],
  "git_panel": { "button": false },
  "tabs": { "file_icons": true, "git_status": true },
  "telemetry": { "diagnostics": false, "metrics": false },
  "unnecessary_code_fade": 0.5,
  "when_closing_with_no_tabs": "keep_window_open",
  "always_treat_brackets_as_autoclosed": true,
  "vim": {
    "use_smartcase_find": true,
    "use_system_clipboard": "on_yank",
    "toggle_relative_line_numbers": true,
  },
  "vim_mode": true,
  "buffer_line_height": { "custom": 1.3 },
  "git": {
    "gutter_debounce": 5,
    "inline_blame": {
      "show_commit_summary": true,
      "min_column": 60,
    },
  },
  "completion_menu_scrollbar": "auto",
  "tab_size": 2,
  "minimap": {
    "current_line_highlight": "all",
    "show": "auto",
  },
  "gutter": { "min_line_number_digits": 3 },
  "drag_and_drop_selection": { "enabled": false },
  "show_signature_help_after_edits": true,
  "which_key": { "enabled": true, "delay_ms": 0 },
  "tab_bar": { "show_pinned_tabs_in_separate_row": true },
  "status_bar": { "show_active_file": true },
  "auto_install_extensions": {
    "ast-grep": true,
    "colorizer": true,
    "csv": true,
    "dockerfile": true,
    "git-firefly": true,
    "grit": true,
    "helm": true,
    "ical": true,
    "ini": true,
    "jj-lsp": true,
    "jsonl": true,
    "log": true,
    "make": true,
    "mcp-server-github": true,
    "mcp-server-linear": true,
    "mcp-server-puppeteer": true,
    "nix": true,
    "nu": true,
    "postgres-context-server": true,
    "powershell": true,
    "proto": true,
    "pylsp": true,
    "python-requirements": true,
    "rainbow-csv": true,
    "sql": true,
    "tailwind-theme": true,
    "terraform": true,
    "toml": true,
    "typescript-snippets": true,
    "xml": true,
  },
}
